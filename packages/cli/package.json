{
  "name": "@loomfsm/cli",
  "version": "0.3.1",
  "type": "module",
  "description": "The loom command-line installer — register the MCP server and authorize projects.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "loom": "./dist/src/bin/loom.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/config": "workspace:*",
    "@loomfsm/daemon": "workspace:*",
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*",
    "@loomfsm/mcp-server": "workspace:*",
    "@loomfsm/server": "workspace:*"
  },
  "optionalDependencies": {
    "@loomfsm/provider-anthropic-sdk": "workspace:*",
    "@loomfsm/provider-ollama": "workspace:*",
    "@loomfsm/provider-openrouter": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
