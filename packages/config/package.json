{
  "name": "@loomfsm/config",
  "version": "0.3.8",
  "type": "module",
  "description": "loom's persistent control layer — the global config + secrets + project catalog, and the one layered resolver every face (CLI today, server/UI later) reads. A leaf: it depends on nothing else in loom and learns no domain. Configure keys/models once; inherit them in every project.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-domain-leak": "node scripts/no-domain-leak.mjs",
    "test": "tsc && pnpm lint:no-domain-leak && node --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "config",
    "secrets"
  ],
  "engines": {
    "node": ">=22"
  }
}
