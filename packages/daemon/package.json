{
  "name": "@loomfsm/daemon",
  "version": "0.1.4",
  "type": "module",
  "description": "Long-lived supervisor over loom's headless driver-loop — drives a project's task server-side, parks on a human gate and wakes on the answer, retries transient failures, recovers in-flight work on restart, and owns the worktree lifecycle.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-domain-leak": "node scripts/no-domain-leak.mjs",
    "test": "tsc && pnpm lint:no-domain-leak && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
