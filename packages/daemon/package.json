{
  "name": "@loomfsm/daemon",
  "version": "0.3.8",
  "type": "module",
  "description": "Long-lived supervisor over loom's headless driver-loop — drives a project's task server-side, parks on a human gate and wakes on the answer, retries transient failures, recovers in-flight work on restart, and owns the worktree lifecycle.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-domain-leak": "node scripts/no-domain-leak.mjs",
    "test": "tsc && pnpm lint:no-domain-leak && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*"
  },
  "devDependencies": {
    "@loomfsm/loader": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/daemon"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "daemon",
    "supervisor",
    "autonomous"
  ],
  "engines": {
    "node": ">=22"
  }
}
