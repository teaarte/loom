{
  "name": "@loomfsm/driver",
  "version": "0.2.0",
  "type": "module",
  "description": "Transport-neutral orchestration runtime for loom — the headless driver-loop, the directive→wire adapter, and the conformant delivery composition shared by every transport.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-domain-leak": "node scripts/no-domain-leak.mjs",
    "test": "tsc && pnpm lint:no-domain-leak && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*",
    "@loomfsm/transport-types": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
