{
  "name": "@loomfsm/kernel",
  "version": "0.1.0",
  "type": "module",
  "description": "Generic finite-state-machine kernel for multi-agent LLM workflows — atomic state, replay-deterministic, zero runtime dependencies.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src",
    "migrations"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-ambient-clock": "node scripts/no-ambient-clock.mjs",
    "test": "tsc && pnpm lint:no-ambient-clock && node --experimental-sqlite --experimental-strip-types --no-warnings --test dist/test/*.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
