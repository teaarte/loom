{
  "name": "@loomfsm/loader",
  "version": "0.3.7",
  "type": "module",
  "description": "loom's build-time assembly layer — discovers and reconciles extensions, validates a bundle's declarative shape, and assembles the Registry the kernel ticks. Runs once at start-up, off the replay hot path; the kernel needs none of it to tick.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --experimental-sqlite --experimental-strip-types --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/loader"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "plugins",
    "registry"
  ],
  "engines": {
    "node": ">=22"
  }
}
