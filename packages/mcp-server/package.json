{
  "name": "@loom/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP transport for loom — exposes the pipeline tools over stdio and assembles the runnable registry.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "loom-mcp-server": "./dist/src/bin/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./bootstrap": {
      "types": "./dist/src/bootstrap.d.ts",
      "import": "./dist/src/bootstrap.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src",
    "cc-adapter"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loom/bundle-code": "workspace:*",
    "@loom/kernel": "workspace:*",
    "@loom/provider-claude-code-shuttle": "workspace:*",
    "@loom/transport-types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@loom/provider-ollama": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
