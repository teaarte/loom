{
  "name": "@loomfsm/mcp-server",
  "version": "0.3.6",
  "type": "module",
  "description": "MCP transport for loom — exposes the pipeline tools over stdio and assembles the runnable registry.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "loom-mcp-server": "./dist/src/bin/stdio.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./bootstrap": {
      "types": "./dist/src/bootstrap.d.ts",
      "import": "./dist/src/bootstrap.js"
    },
    "./parse-task-args": {
      "types": "./dist/src/lib/parse-task-args.d.ts",
      "import": "./dist/src/lib/parse-task-args.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src",
    "cc-adapter"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/bundle-code": "workspace:*",
    "@loomfsm/config": "workspace:*",
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*",
    "@loomfsm/loader": "workspace:*",
    "@loomfsm/provider-claude-code-shuttle": "workspace:*",
    "@loomfsm/transport-types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@loomfsm/bundle-spec": "workspace:*",
    "@loomfsm/provider-ollama": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "mcp",
    "model-context-protocol",
    "claude"
  ],
  "engines": {
    "node": ">=22"
  }
}
