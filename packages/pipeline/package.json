{
  "name": "@loom/pipeline",
  "version": "0.1.0",
  "type": "module",
  "description": "Install loom in one step: npm i -g @loom/pipeline && loom setup. Pulls the CLI, the MCP server, the default bundle, and the zero-config provider.",
  "license": "Apache-2.0",
  "bin": {
    "loom": "./bin/loom.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "dependencies": {
    "@loom/bundle-code": "workspace:*",
    "@loom/cli": "workspace:*",
    "@loom/kernel": "workspace:*",
    "@loom/mcp-server": "workspace:*",
    "@loom/provider-claude-code-shuttle": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
