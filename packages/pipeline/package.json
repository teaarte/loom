{
  "name": "@loomfsm/pipeline",
  "version": "0.3.9",
  "type": "module",
  "description": "Install loom in one step: npm i -g @loomfsm/pipeline && loom setup. Pulls the CLI, the MCP server, the default bundle, and the zero-config provider.",
  "license": "Apache-2.0",
  "bin": {
    "loom": "./bin/loom.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "dependencies": {
    "@loomfsm/bundle-code": "workspace:*",
    "@loomfsm/cli": "workspace:*",
    "@loomfsm/daemon": "workspace:*",
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*",
    "@loomfsm/loader": "workspace:*",
    "@loomfsm/mcp-server": "workspace:*",
    "@loomfsm/provider-claude-code-shuttle": "workspace:*",
    "@loomfsm/server": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/pipeline"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "claude",
    "mcp",
    "code-review",
    "agent-orchestrator",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  }
