{
  "name": "@loomfsm/provider-anthropic-sdk",
  "version": "0.3.4",
  "type": "module",
  "description": "Direct Anthropic provider for loom — runs agents through the Anthropic SDK with prompt caching and idempotent spawns.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*",
    "@anthropic-ai/sdk": "^0.99.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
