{
  "name": "@loomfsm/provider-anthropic-sdk",
  "version": "0.3.9",
  "type": "module",
  "description": "Direct Anthropic provider for loom — runs agents through the Anthropic SDK with prompt caching and idempotent spawns.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*",
    "@anthropic-ai/sdk": "^0.99.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/providers/anthropic-sdk"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "human-in-the-loop",
    "audit-trail",
    "state-machine",
    "durable-execution",
    "anthropic",
    "claude",
    "provider"
  ],
  "engines": {
    "node": ">=22"
  }
}
