{
  "name": "@loomfsm/repo-memory",
  "version": "0.3.9",
  "type": "module",
  "description": "Persistent, model-agnostic structural memory of a code repository — a delta-refreshed markdown brief (with file:line anchors) that warm-starts planning agents so they cite structure instead of re-reading the whole tree each run. Ambient transport, outside the kernel's replay graph; the kernel never depends on it.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "tsc && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://loomfsm.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teaarte/loom.git",
    "directory": "packages/repo-memory"
  },
  "bugs": {
    "url": "https://github.com/teaarte/loom/issues"
  },
  "keywords": [
    "llm",
    "agents",
    "ai-agents",
    "orchestration",
    "code-analysis",
    "repository-map",
    "context",
    "prompt-engineering",
    "token-optimization"
  ],
  "engines": {
    "node": ">=22"
  }
}
