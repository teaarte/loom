{
  "name": "@loomfsm/server",
  "version": "0.3.3",
  "type": "module",
  "description": "Network control plane for loom — an HTTP transport over the headless driver-loop and a registry that supervises a fleet of projects from one process. Submit a task, read status, and answer a gate over localhost; intake adapters (a dashboard, a chat bot, an issue poller) are thin clients of POST /submit.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build",
    "lint:no-domain-leak": "node scripts/no-domain-leak.mjs",
    "test": "tsc && pnpm lint:no-domain-leak && node --experimental-sqlite --no-warnings --test dist/test/*.js"
  },
  "dependencies": {
    "@loomfsm/config": "workspace:*",
    "@loomfsm/daemon": "workspace:*",
    "@loomfsm/dashboard": "workspace:*",
    "@loomfsm/driver": "workspace:*",
    "@loomfsm/kernel": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
