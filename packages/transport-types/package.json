{
  "name": "@loomfsm/transport-types",
  "version": "0.1.4",
  "type": "module",
  "description": "Shared wire-response types for loom transports.",
  "license": "Apache-2.0",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@loomfsm/kernel": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
